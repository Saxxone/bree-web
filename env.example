# REST client base URL — must include the Nest global prefix (e.g. http://localhost:3000/api).
VITE_WS_URL=
VITE_API_BASE_URL=
VITE_GOOGLE_AUTH_CLIENT_ID=
VITE_GOOGLE_OAUTH_URL=

# Coin top-up packages are defined in afovid-api (Prisma seed). Set Stripe Price IDs there
